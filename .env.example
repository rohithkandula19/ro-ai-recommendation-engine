# Core DB + infra
DATABASE_URL=postgresql+asyncpg://recuser:recpass@postgres:5432/recengine
SYNC_DATABASE_URL=postgresql://recuser:recpass@postgres:5432/recengine
REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
CLICKHOUSE_URL=http://clickhouse:8123
ML_SERVICE_URL=http://ml_service:8001
APP_URL=http://localhost:3000

# Auth
SECRET_KEY=change-me-in-production-use-32-chars-min-abcdef
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Postgres
POSTGRES_USER=recuser
POSTGRES_PASSWORD=recpass
POSTGRES_DB=recengine

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ML
MODEL_VERSION=v1
LOG_LEVEL=INFO

# LLM provider — pick one (auto-detect by priority)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

# Content ingestion (any one is enough)
TMDB_API_KEY=
OMDB_API_KEY=
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# Email (for password reset)
RESEND_API_KEY=
SMTP_URL=
EMAIL_FROM=RO Rec <noreply@ro-rec.local>

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Cloud
PINECONE_API_KEY=
PINECONE_ENV=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
