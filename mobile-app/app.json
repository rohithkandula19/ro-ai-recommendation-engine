{
  "expo": {
    "name": "RO",
    "slug": "ro-rec-engine",
    "scheme": "ro",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0b0b0b"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.ro.app" },
    "android": { "package": "com.ro.app" },
    "web": { "bundler": "metro" },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": {
      "apiUrl": "https://api.ro-rec.com"
    }
  }
}
